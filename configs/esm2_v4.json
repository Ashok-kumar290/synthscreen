{
    "model_type": "esm2",
    "dataset_path": "data/processed/funcscreen_protein_v4_dataset",
    "output_dir": "models/esm2_v4",
    "max_seq_length": 512,
    "lora_r": 16,
    "lora_alpha": 32,
    "lora_dropout": 0.1,
    "epochs": 5,
    "batch_size": 8,
    "eval_batch_size": 16,
    "learning_rate": 2e-4,
    "weight_decay": 0.01,
    "warmup_ratio": 0.1,
    "lr_scheduler_type": "cosine",
    "fp16": true,
    "use_focal_loss": true,
    "focal_gamma": 2.0,
    "focal_alpha": null,
    "use_class_weights": true,
    "label_smoothing": 0.05,
    "early_stopping_patience": 2,
    "early_stopping_threshold": 0.001,
    "max_grad_norm": 1.0,
    "hard_mining_enabled": true,
    "hard_mining_rounds": 2,
    "hard_mining_threshold": 0.3,
    "hard_mining_oversample": 3,
    "max_train_val_gap": 0.10,
    "logging_steps": 50,
    "gradient_accumulation_steps": 1,
    "version": "v4"
}
